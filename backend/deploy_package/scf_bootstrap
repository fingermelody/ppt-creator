#!/bin/bash

# ============================================
# SCF Web 函数启动脚本
# 用于启动 FastAPI 应用
# ============================================

# 设置 Python 路径 - 包含 Layer 依赖
export PYTHONPATH="/opt/python/lib/python3.9/site-packages:/var/user:$PYTHONPATH"

# 切换到用户代码目录
cd /var/user

# 使用 Python 3.9 启动 FastAPI 应用
# SCF Web 函数要求监听 9000 端口
exec /var/lang/python39/bin/python3 -m uvicorn app.main:app --host 0.0.0.0 --port 9000 --workers 1
