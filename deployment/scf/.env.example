# ============================================
# SCF 部署环境变量模板
# 复制此文件为 .env 并填写实际值
# ============================================

# 部署阶段: dev / test / prod
STAGE=dev

# 腾讯云地域
REGION=ap-guangzhou

# 数据库配置（使用腾讯云 MySQL / TDSQL）
DATABASE_URL=mysql+pymysql://user:password@host:3306/ppt_rsd

# Redis 配置（使用腾讯云 Redis）
REDIS_URL=redis://:password@host:6379/0

# 应用密钥
SECRET_KEY=your-secret-key-here

# COS 配置
COS_BUCKET=ppt-rsd-files-xxxxxxxxxx
COS_REGION=ap-guangzhou
COS_SECRET_ID=your-secret-id
COS_SECRET_KEY=your-secret-key

# VPC 配置（如需访问内网资源）
VPC_ID=vpc-xxxxxxxx
SUBNET_ID=subnet-xxxxxxxx

# SSL 证书 ID（用于自定义域名 HTTPS）
SSL_CERT_ID=

# 腾讯云 API 密钥（用于 CI/CD 部署）
TENCENT_SECRET_ID=your-tencent-secret-id
TENCENT_SECRET_KEY=your-tencent-secret-key
