# ============================================
# PPT-RSD 生产环境部署配置模板
# 复制此文件为 config.env 并填入实际值
# ============================================

# 部署环境
STAGE=prod
REGION=ap-guangzhou

# ============================================
# 域名配置
# ============================================
DOMAIN=your-domain.com
FRONTEND_DOMAIN=your-domain.com
API_DOMAIN=api.your-domain.com

# ============================================
# 端口配置（固定）
# ============================================
# 前端: 通过 CDN 访问，HTTPS 443
# 后端: 通过 API 网关访问，HTTPS 443
# 本地开发端口
LOCAL_FRONTEND_PORT=5173
LOCAL_BACKEND_PORT=8000

# ============================================
# 腾讯云账号信息（必填）
# ============================================
TENCENT_APP_ID=your-app-id
TENCENT_SECRET_ID=your-secret-id
TENCENT_SECRET_KEY=your-secret-key

# ============================================
# COS 配置（前端静态资源托管）
# ============================================
COS_BUCKET=your-bucket-name
COS_REGION=ap-guangzhou
COS_WEBSITE_ENDPOINT=http://your-bucket.cos-website.ap-guangzhou.myqcloud.com
COS_DOMAIN=your-bucket.cos.ap-guangzhou.myqcloud.com

# ============================================
# SCF 云函数配置（后端 API）
# ============================================
SCF_FUNCTION_NAME=your-function-name
SCF_RUNTIME=Python3.9
SCF_MEMORY=512
SCF_TIMEOUT=30

# ============================================
# API 网关配置
# ============================================
APIGW_SERVICE_ID=your-service-id
APIGW_SERVICE_NAME=your-service-name
APIGW_API_ID=your-api-id
APIGW_ENDPOINT=http://your-service-id.your-app-id.gz.tencentapigw.com.cn/release
