# ============================================
# PPT-RSD 项目环境变量配置模板
# 独立云资源架构（TKE + TDSQL-C + Redis）
# 复制此文件为 .env 并填入实际值
# ============================================

# ============================================
# 腾讯云基础配置（必填）
# ============================================
TENCENT_SECRET_ID=your-secret-id
TENCENT_SECRET_KEY=your-secret-key
TENCENT_REGION=ap-guangzhou

# ============================================
# TKE 容器集群配置
# ============================================
TKE_CLUSTER_ID=cls-xxxxxx
TKE_REGION=ap-guangzhou
TKE_NAMESPACE=ppt-rsd-prod

# ============================================
# 数据库配置 - TDSQL-C MySQL Serverless（必填）
# ============================================
DATABASE_URL=mysql+pymysql://root:password@host:3306/ppt_rsd
DB_HOST=your-tdsql-host.sql.tencentcdb.com
DB_PORT=3306
DB_NAME=ppt_rsd
DB_USER=root
DB_PASSWORD=your-db-password

# ============================================
# Redis 配置 - 腾讯云 Redis（必填）
# ============================================
REDIS_URL=redis://:password@host:6379/0
REDIS_HOST=your-redis-host.redis.rds.tencentcloud.com
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0

# ============================================
# 对象存储配置 - 腾讯云 COS（必填）
# ============================================
COS_SECRET_ID=your-secret-id
COS_SECRET_KEY=your-secret-key
COS_REGION=ap-guangzhou
COS_BUCKET=ppt-rsd-files
COS_DOMAIN=https://ppt-rsd-files.cos.ap-guangzhou.myqcloud.com

# ============================================
# 容器镜像仓库 - 腾讯云 TCR
# ============================================
TCR_REGISTRY=ccr.ccs.tencentyun.com
TCR_NAMESPACE=codebuddy-ppt-creator
TCR_USERNAME=100000763815
TCR_PASSWORD=your-tcr-password

# ============================================
# Elasticsearch Serverless 配置（向量检索）
# ============================================
ES_HOST=http://space-k4t5xi0i.ap-guangzhou.qcloudes.com
ES_APP_ID=space-k4t5xi0i
ES_USERNAME=elastic
ES_PASSWORD=caonidaye@123
ES_INDEX_NAME=ppt_slides

# ============================================
# 负载均衡 CLB 配置
# ============================================
CLB_VIP=your-clb-vip
CLB_DOMAIN=ppt.bottlepeace.com

# ============================================
# LLM 模型配置（可选，至少配置一个启用 AI 功能）
# ============================================
LLM_ENABLED=true
LLM_DEFAULT_PROVIDER=hunyuan

# 腾讯混元大模型
HUNYUAN_SECRET_ID=your-secret-id
HUNYUAN_SECRET_KEY=your-secret-key
HUNYUAN_MODEL=hunyuan-lite

# 通义千问（可选）
QWEN_API_KEY=your-api-key
QWEN_MODEL=qwen-turbo

# OpenAI（可选）
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# ============================================
# 应用配置
# ============================================
APP_NAME=PPT-RSD
APP_ENV=production
DEBUG=false
SECRET_KEY=your-random-secret-key-for-jwt

# 后端服务配置
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# 前端配置
FRONTEND_URL=https://ppt.bottlepeace.com

# ============================================
# 功能开关
# ============================================
ENABLE_REGISTRATION=true
ENABLE_PPT_REFINEMENT=true
MAX_UPLOAD_SIZE=104857600
MAX_PAGES_PER_DOCUMENT=200
