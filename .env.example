# ============================================
# PPT-RSD 项目环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================

# ============================================
# 腾讯云基础配置（必填）
# ============================================
TENCENT_SECRET_ID=your-secret-id
TENCENT_SECRET_KEY=your-secret-key
TENCENT_REGION=ap-guangzhou

# ============================================
# 数据库配置 - TDSQL-C PostgreSQL（必填）
# ============================================
DATABASE_URL=postgresql://username:password@host:port/ppt_rsd
DB_HOST=your-tdsql-endpoint
DB_PORT=5432
DB_NAME=ppt_rsd
DB_USER=your-db-user
DB_PASSWORD=your-db-password

# ============================================
# Redis配置 - 腾讯云Redis（必填）
# ============================================
REDIS_URL=redis://:password@host:port/0
REDIS_HOST=your-redis-endpoint
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0

# ============================================
# 对象存储配置 - 腾讯云COS（必填）
# ============================================
COS_SECRET_ID=your-secret-id
COS_SECRET_KEY=your-secret-key
COS_REGION=ap-guangzhou
COS_BUCKET=ppt-creator-files
COS_DOMAIN=https://ppt-rsd-files.cos.ap-guangzhou.myqcloud.com

# ============================================
# 容器镜像仓库 - 腾讯云TCR（可选）
# ============================================
TCR_REGISTRY=ppt-creator-registry.tencentcloudcr.com
TCR_NAMESPACE=ppt-creator
TCR_USERNAME=your-tcr-username
TCR_PASSWORD=your-tcr-password

# ============================================
# LLM模型配置（可选，至少配置一个启用AI功能）
# ============================================
LLM_ENABLED=true
LLM_DEFAULT_PROVIDER=hunyuan

# 腾讯混元大模型
HUNYUAN_SECRET_ID=your-secret-id
HUNYUAN_SECRET_KEY=your-secret-key
HUNYUAN_MODEL=hunyuan-lite

# 百度文心一言（可选）
WENXIN_API_KEY=your-api-key
WENXIN_SECRET_KEY=your-secret-key
WENXIN_MODEL=ernie-lite-8k

# 阿里通义千问（可选）
QWEN_API_KEY=your-api-key
QWEN_MODEL=qwen-turbo

# OpenAI（可选）
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# Claude（可选）
CLAUDE_API_KEY=your-api-key
CLAUDE_MODEL=claude-3-haiku-20240307

# 自定义模型（可选，OpenAI兼容格式）
CUSTOM_MODEL_NAME=my-custom-model
CUSTOM_API_URL=https://your-custom-api.com/v1
CUSTOM_API_KEY=your-api-key
CUSTOM_MODEL_IDENTIFIER=gpt-4

# ============================================
# 应用配置
# ============================================
APP_NAME=PPT-Creator
APP_ENV=development
DEBUG=true
SECRET_KEY=your-random-secret-key-for-jwt

# 后端服务配置
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# 前端配置
FRONTEND_URL=http://localhost:3000

# ============================================
# 功能开关
# ============================================
ENABLE_REGISTRATION=true
ENABLE_PPT_REFINEMENT=true
MAX_UPLOAD_SIZE=104857600
MAX_PAGES_PER_DOCUMENT=200
